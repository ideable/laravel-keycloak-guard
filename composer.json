{
    "name": "ideable/laravel-keycloak-guard",
    "description": "Maintained Keycloak Guard for Laravel APIs",
    "keywords": [
        "laravel",
        "keycloak"
    ],
    "homepage": "https://github.com/ideable/laravel-keycloak-guard",
    "support": {
        "issues": "https://github.com/ideable/laravel-keycloak-guard/issues",
        "source": "https://github.com/ideable/laravel-keycloak-guard"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Ideable"
        },
        {
            "name": "Robson Tenório"
        }
    ],
    "require": {
        "firebase/php-jwt": "^7.0",
        "php": "^8.2",
        "ext-openssl": "*"
    },
    "autoload": {
        "psr-4": {
            "KeycloakGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KeycloakGuard\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "php -d pcov.enabled=1 ./vendor/bin/phpunit --coverage-clover=.coverage/clover.xml --coverage-html=.coverage",
        "post-autoload-dump": [
            "@php ./vendor/bin/testbench package:discover --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "KeycloakGuard\\KeycloakGuardServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.8",
        "orchestra/testbench": "^10.0",
        "friendsofphp/php-cs-fixer": "^3.10",
        "nunomaduro/collision": "^8.6"
    }
}
